<% content_for :title, @scenario.title %>
<% currency = @scenario.currency %>

<header class="flex flex-col gap-2">
  <span class="eyebrow"><%= eyebrow(currency, @comparison.amount, @comparison.horizon_years) %></span>
  <h1 class="font-display text-2xl leading-tight tracking-tight"><%= copy_tag(Monte::Headline.call(@scenario, @results), currency: currency) %></h1>
</header>

<%# Fan-of-futures chart (#4): per-step bands + sampled spaghetti, drawn from the
    frozen snapshot by chart_controller.js. %>
<div class="flex flex-col gap-2"
     data-controller="chart"
     data-chart-data-value="<%= @results[:chart].to_json %>"
     data-chart-amount-value="<%= @comparison.amount %>"
     data-chart-currency-value="<%= currency %>">
  <div class="aspect-[2/1] overflow-hidden rounded-xl border border-rule bg-paper-2/60">
    <canvas data-chart-target="canvas" class="block h-full w-full"></canvas>
  </div>
  <div class="flex justify-between font-mono text-[9px] text-ink-3">
    <span>Now</span>
    <span>Year <%= @comparison.horizon_years %></span>
  </div>
</div>

<%= render "distribution_bars", results: @results, currency: currency, scenario: @scenario %>

<%= render "insight", scenario: @scenario, results: @results, comparison: @comparison, currency: currency %>

<p class="font-mono text-[10px] leading-relaxed text-ink-3">
  Illustrative simulation, not financial advice — based on historical data as of
  <%= @comparison.data_as_of.to_fs(:long) %>.
</p>

<nav class="mt-auto flex gap-1.5 pt-2">
  <%= link_to "Tweak", scenario_path(@scenario), class: "btn-secondary" %>
  <%= link_to "Another", root_path, class: "btn-secondary" %>
</nav>
